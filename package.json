{
  "name": "@yawlabs/aws-mcp",
  "version": "1.5.3",
  "mcpName": "io.github.YawLabs/aws-mcp",
  "description": "AWS MCP server — call any AWS API from AI assistants, with first-class SSO re-login (no more 'browser won't open' dead ends)",
  "license": "MIT",
  "author": "YawLabs <contact@yaw.sh>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YawLabs/aws-mcp.git"
  },
  "keywords": [
    "aws",
    "mcp",
    "model-context-protocol",
    "ai",
    "sso",
    "iam-identity-center"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aws-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node build.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist/**/*.test.js",
    "test:ci": "npm run test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^26.0.1",
    "@types/turndown": "^5.0.6",
    "esbuild": "^0.28.1",
    "node-html-parser": "^8.0.3",
    "postject": "^1.0.0-alpha.6",
    "turndown": "^7.2.4",
    "typescript": "^7.0.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "hono": "^4.12.25",
    "qs": "^6.15.2"
  },
  "engines": {
    "node": ">=22"
  }
}
