{
  "name": "@yawlabs/aws-mcp",
  "version": "0.4.0",
  "description": "AWS MCP server — call any AWS API from AI assistants, with first-class SSO re-login (no more 'browser won't open' dead ends)",
  "license": "MIT",
  "author": "YawLabs <contact@yaw.sh>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YawLabs/aws-mcp.git"
  },
  "keywords": [
    "aws",
    "mcp",
    "model-context-protocol",
    "ai",
    "sso",
    "iam-identity-center"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aws-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node build.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist/**/*.test.js",
    "test:ci": "npm run test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@biomejs/biome": "^2.4.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22"
  }
}
